rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Document
    function isValidDocument(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'docMode', 'company', 'letter', 'style', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && (data.docMode == 'letter' || data.docMode == 'proposal')
        && data.company is map
        && data.letter is map
        && data.style is map
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidDocumentUpdate(data, existingData) {
      return data.keys().hasAll(['id', 'userId', 'title', 'docMode', 'company', 'letter', 'style', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.id == existingData.id
        && data.userId == existingData.userId
        && data.title is string && data.title.size() <= 200
        && (data.docMode == 'letter' || data.docMode == 'proposal')
        && data.company is map
        && data.letter is map
        && data.style is map
        && data.createdAt == existingData.createdAt
        && data.updatedAt == request.time;
    }

    match /documents/{documentId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(documentId) 
        && isValidDocument(request.resource.data);
        
      allow update: if isSignedIn() 
        && isValidId(documentId)
        && isOwner(resource.data.userId)
        && isValidDocumentUpdate(request.resource.data, resource.data);
        
      allow delete: if isOwner(resource.data.userId);
    }
  }
}

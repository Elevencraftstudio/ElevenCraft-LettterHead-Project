{
  "entities": {
    "Document": {
      "title": "Document",
      "description": "A saved letterhead document or proposal configuration",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the document"
        },
        "userId": {
          "type": "string",
          "description": "UID of the owner of this document"
        },
        "title": {
          "type": "string",
          "description": "Human readable name of the document"
        },
        "docMode": {
          "type": "string",
          "enum": ["letter", "proposal"],
          "description": "Type of document"
        },
        "company": {
          "type": "object",
          "description": "Company details used in the header"
        },
        "letter": {
          "type": "object",
          "description": "Standard letter contents"
        },
        "proposal": {
          "type": "object",
          "description": "Proposal/quote contents and budget"
        },
        "style": {
          "type": "object",
          "description": "Layout and styling configs"
        },
        "createdAt": {
          "type": "object",
          "format": "google.protobuf.Timestamp",
          "description": "Creation date"
        },
        "updatedAt": {
          "type": "object",
          "format": "google.protobuf.Timestamp",
          "description": "Last updated date"
        }
      },
      "required": ["id", "userId", "title", "docMode", "company", "letter", "style", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "documents/{documentId}": {
      "schema": "Document",
      "description": "Collection of saved stationary letters and proposals"
    }
  }
}
